{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and health data",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["EMPLOYEE", "DOCTOR", "HEAD_OF_UNIT", "DATA_ENTRY", "AUDITOR"] },
        "healthProfile": { "$ref": "HealthProfile" },
        "activePlans": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "name", "email", "role"]
    },
    "HealthProfile": {
      "title": "HealthProfile",
      "description": "User health metrics",
      "type": "object",
      "properties": {
        "bloodType": { "type": "string" },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "age": { "type": "number" },
        "chronicDiseases": { "type": "array", "items": { "type": "string" } },
        "pathway": { "type": "string" },
        "dailyWaterIntake": { "type": "number" },
        "systolicBP": { "type": "number" },
        "diastolicBP": { "type": "number" },
        "hba1c": { "type": "number" }
      }
    },
    "Claim": {
      "title": "Claim",
      "description": "Medical claim submission",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "employeeId": { "type": "string" },
        "employeeName": { "type": "string" },
        "submissionDate": { "type": "string" },
        "status": { "type": "string" },
        "totalAmount": { "type": "number" },
        "referenceNumber": { "type": "string" },
        "invoiceCount": { "type": "number" },
        "description": { "type": "string" },
        "location": { "type": "string" },
        "department": { "type": "string" },
        "invoices": { "type": "array", "items": { "type": "object" } },
        "auditTrail": { "type": "array", "items": { "type": "object" } }
      },
      "required": ["id", "employeeId", "status", "totalAmount"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["STATUS_CHANGE", "REJECTION", "HEALTH_GOAL", "SYSTEM"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "link": { "type": "string" }
      },
      "required": ["id", "userId", "title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/claims/{claimId}": {
      "schema": "Claim",
      "description": "Medical claims"
    },
    "/chronic_applications/{appId}": {
      "schema": "ChronicApplication",
      "description": "Chronic disease enrollment applications"
    },
    "/healthPlans/{planId}": {
      "schema": "HealthPlan",
      "description": "Personalized health plans and daily tasks"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "In-app notifications"
    }
  }
}

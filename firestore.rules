rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == 'magdezaroog@gmail.com' || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['DOCTOR', 'HEAD_OF_UNIT', 'INTERNAL_AUDITOR', 'DATA_ENTRY', 'ADMIN', 'SYSTEM_ADMIN']));
    }

    match /users/{userId} {
      allow read, write: if isAuthenticated();
    }

    match /claims/{claimId} {
      allow read, write: if isAuthenticated();
    }

    match /chronic_applications/{appId} {
      allow read, write: if isAuthenticated();
    }

    match /healthPlans/{planId} {
      allow read, write: if isAuthenticated();
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId);
      allow write: if isAuthenticated();
    }

    match /system_logs/{logId} {
      allow read, write: if isAuthenticated();
    }
  }
}
